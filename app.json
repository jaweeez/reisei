{
  "expo": {
    "name": "Reisei",
    "description": "Stay level. Daily check-ins, streaks, and a crew that expects you to show up.",
    "slug": "reisei",
    "version": "1.5.0",
    "scheme": "reisei",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1B1918",
    "icon": "./assets/brand/app-icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.muworks.reisei",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.muworks.reisei",
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/icon-adaptive.png",
        "backgroundColor": "#1B1918"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "server",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/splash-icon.png",
          "backgroundColor": "#1B1918",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#B8863E"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "67619966-efbf-4b52-90a2-849bd570305b"
      }
    },
    "owner": "mu-works-llc"
  }
}
