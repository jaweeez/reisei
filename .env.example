# =====================================================================
# Reisei — environment config. Copy to .env.local and fill in.
# .env.local is gitignored. In production, set the server (secret) vars
# in Vercel project settings, not in any committed file.
#
# EXPO_PUBLIC_* → inlined into the client bundle (public, not secret).
# everything else → server-only (API routes + CLI scripts). Keep secret.
# =====================================================================

# --- Client (public) ---
EXPO_PUBLIC_APP_URL=
EXPO_PUBLIC_API_URL=
NODE_ENV=development

# --- Database (Neon Postgres) ---
# Two lanes. On Vercel (serverless) the runtime URLs must use the "-pooler" host;
# migrations must NOT (PgBouncer can't do DDL-in-txn / advisory locks).
DATABASE_URL=          # owner role, RUNTIME (auth, entitlement, billing, webhooks, cron) — pooler host on Vercel
APP_DATABASE_URL=      # restricted reisei_app role, RUNTIME request queries (RLS) — pooler host on Vercel
DIRECT_DATABASE_URL=   # owner role, DIRECT (non-pooler) host — migrations/provision/ingest only. Falls back to DATABASE_URL if unset.

# --- Auth (session + passkeys) ---
AUTH_SESSION_SECRET=
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=Reisei
WEBAUTHN_ORIGIN=

# --- AWS (shared creds) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- S3 + CloudFront (media) ---
REISEI_AWS_S3_BUCKET=
REISEI_CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=

# --- SES (email) ---
SES_FROM_EMAIL=
SES_REGION=us-east-1

# --- AppSync Events (crew realtime) ---
EXPO_PUBLIC_APPSYNC_EVENTS_HTTP_ENDPOINT=
EXPO_PUBLIC_APPSYNC_EVENTS_REALTIME_ENDPOINT=
EXPO_PUBLIC_APPSYNC_REGION=us-east-1
APPSYNC_EVENTS_NAMESPACE=crew
APPSYNC_EVENTS_API_KEY=
APPSYNC_AUTHORIZER_SECRET=

# --- Stripe (web billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_SEAT_MONTHLY=
STRIPE_PRICE_SEAT_ANNUAL=
STRIPE_PRICE_ORG_MONTHLY=
STRIPE_PRICE_ORG_ANNUAL=
STRIPE_PRICE_FACILITY_MONTHLY=
STRIPE_PRICE_FACILITY_ANNUAL=

# --- RevenueCat (mobile IAP) ---
# Test Store only: used by an Expo development build. Never set this for a
# production build or submit a build that contains a test_ key.
EXPO_PUBLIC_REVENUECAT_TEST_KEY=test_NDlwmOizqCXeLEdnyulQOQRgLUK
EXPO_PUBLIC_REVENUECAT_USE_TEST_STORE=false
# Public, platform-specific RevenueCat SDK keys for EAS preview/production.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT=Reisei Pro
REVENUECAT_WEBHOOK_AUTH=
REVENUECAT_SECRET_API_KEY=

# --- Inngest (jobs/cron) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Expo push ---
EXPO_ACCESS_TOKEN=

# --- Sentry ---
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Coach RAG pipeline (Tavily → Voyage → Claude) ---
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-haiku-4-5
VOYAGE_API_KEY=
TAVILY_API_KEY=
# INGEST_SCRAPE_CACHE=.cache/scrape.json
# Secures the coach cron GET /api/coach/tick (Vercel Cron sends Authorization: Bearer $CRON_SECRET)
CRON_SECRET=
