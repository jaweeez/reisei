{
  "name": "reisei",
  "main": "expo-router/entry",
  "version": "1.5.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export -p web",
    "android:build": "eas build --platform android --profile preview",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:provision": "tsx scripts/provision-app-role.ts",
    "create:admin": "tsx scripts/create-admin.ts",
    "setup:stripe": "tsx scripts/setup-stripe.ts",
    "ingest": "tsx scripts/ingest.ts",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@aws-sdk/client-sesv2": "^3.1079.0",
    "@expo-google-fonts/big-shoulders-display": "^0.2.3",
    "@expo-google-fonts/ibm-plex-mono": "^0.4.1",
    "@expo-google-fonts/ibm-plex-sans": "^0.4.1",
    "@neondatabase/serverless": "^1.1.0",
    "@tavily/core": "^0.7.6",
    "ai": "^4.3.19",
    "bcryptjs": "^3.0.3",
    "expo": "~57.0.2",
    "expo-build-properties": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.3",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "pg": "^8.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-purchases": "^10.4.2",
    "react-native-purchases-ui": "^10.4.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "29.5.14",
    "@types/pg": "^8.20.0",
    "@types/react": "~19.2.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/db/"
    ],
    "moduleNameMapper": {
      "^@/assets/(.*)$": "<rootDir>/assets/$1",
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
